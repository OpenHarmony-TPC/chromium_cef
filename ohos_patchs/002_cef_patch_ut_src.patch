 void OhosOzoneUIControlsTestHelper::SendMouseEvent(
@@ -109,6 +174,56 @@ void OhosOzoneUIControlsTestHelper::SendMouseEvent(
   gfx::Point mouse_loc_in_screen_px = mouse_loc_in_screen;
   // TODO(crbug.com/1430805): fix this conversion.
   host->ConvertDIPToPixels(&mouse_loc_in_screen_px);
+
+  OH_NativeXComponent_MouseEvent mouse_event;
+  mouse_event.x = mouse_loc.x();
+  mouse_event.y = mouse_loc.y();
+  mouse_event.screenX = mouse_loc_in_screen_px.x();
+  mouse_event.screenY = mouse_loc_in_screen_px.y();
+
+  int flags = 0;
+  if (accelerator_state & ui_controls::kShift) {
+    flags |= ui::EF_SHIFT_DOWN;
+  }
+  if (accelerator_state & ui_controls::kControl) {
+    flags |= ui::EF_CONTROL_DOWN;
+  }
+  if (accelerator_state & ui_controls::kAlt) {
+    flags |= ui::EF_ALT_DOWN;
+  }
+
+  switch (type) {
+    case ui_controls::MouseButton::LEFT:
+      mouse_event.button = OH_NATIVEXCOMPONENT_LEFT_BUTTON;
+      break;
+    case ui_controls::MouseButton::MIDDLE:
+      mouse_event.button = OH_NATIVEXCOMPONENT_MIDDLE_BUTTON;
+      break;
+    case ui_controls::MouseButton::RIGHT:
+      mouse_event.button = OH_NATIVEXCOMPONENT_RIGHT_BUTTON;
+      break;
+  }
+
+  int64_t default_display_id =
+      display::Screen::GetScreen()->GetPrimaryDisplay().id();
+  EventFlags key_flags = static_cast<EventFlags>(flags);
+  if (button_state & ui_controls::DOWN) {
+    mouse_event.action = OH_NATIVEXCOMPONENT_MOUSE_PRESS;
+    auto* event_source =
+        reinterpret_cast<OhosEventSource*>(PlatformEventSource::GetInstance());
+    event_source->OnMouseEvent(widget, mouse_event, default_display_id,
+                               key_flags);
+    button_down_mask |= flags;
+  }
+
+  if (button_state & ui_controls::UP) {
+    mouse_event.action = OH_NATIVEXCOMPONENT_MOUSE_RELEASE;
+    auto* event_source =
+        reinterpret_cast<OhosEventSource*>(PlatformEventSource::GetInstance());
+    event_source->OnMouseEvent(widget, mouse_event, default_display_id,
+                               key_flags);
+    button_down_mask &= ~flags;
+  }
 }
 
