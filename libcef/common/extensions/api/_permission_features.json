  // OHOS_NOTIFICATION
  "notifications": {
    "channel": "stable",
    "extension_types": [
      "extension", "legacy_packaged_app", "hosted_app", "platform_app"
    ]
  },
  "system.display": [
    {
      "channel": "stable",
      "extension_types": ["extension", "legacy_packaged_app", "platform_app"]
    },
    {
      "channel": "stable",
      "extension_types": ["hosted_app"]
    }
