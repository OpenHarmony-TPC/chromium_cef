diff --git a/src/net/cert/cert_verify_proc_ohos.cc b/src/net/cert/cert_verify_proc_ohos.cc
old mode 100755
new mode 100644
index 69155e3ec2..49be7b92b9
--- a/src/net/cert/cert_verify_proc_ohos.cc
+++ b/src/net/cert/cert_verify_proc_ohos.cc
@@ -13,6 +13,8 @@
 #include "base/files/file_util.h"
 #include "base/logging.h"
 #include "base/notreached.h"
+#include "base/path_service.h"
+#include "base/threading/thread_restrictions.h"
 #include "crypto/hash.h"
 #include "crypto/sha2.h"
 #include "net/cert/asn1_util.h"
@@ -36,6 +38,9 @@
 #include "third_party/boringssl/src/pki/parsed_certificate.h"
 #include "url/gurl.h"
 
+#include <filesystem>
+namespace fs = std::filesystem;
+
 using ohos::adapter::CertManagerAdapter;
 #define ROOT_CERT "/etc/ssl/certs/cacert.pem"
 #define USER_CACERT_PREFIX "/data/certificates/user_cacerts/"
@@ -318,7 +323,17 @@ class VerifyProcOHOSInner {
     }
 
     // Parse the root certificate file
-    if (X509_load_cert_crl_file(look_up, ROOT_CERT, X509_FILETYPE_PEM) == 0) {
+    base::FilePath src_root;
+    {
+      base::ScopedAllowBlockingForTesting allow_blocking;
+      base::PathService::Get(base::DIR_SRC_TEST_DATA_ROOT, &src_root);
+    }
+    src_root = src_root.Append(FILE_PATH_LITERAL("root_certs/cacert.pem"));
+    std::string cert_path = ROOT_CERT;
+    if (fs::exists(src_root.AsUTF8Unsafe())) {
+      cert_path = src_root.AsUTF8Unsafe();
+    }
+    if (X509_load_cert_crl_file(look_up, cert_path.c_str(), X509_FILETYPE_PEM) == 0) {
       LOG(ERROR) << "CertVerify() failed, Root certificate number is 0";
       return X509_V_ERR_UNSPECIFIED;
     }
