+mojo::PendingRemote<network::mojom::CustomProxyConnectionObserver>
+FallbackProxyService::NewProxyConnectionObserverRemote() {
+  mojo::PendingRemote<network::mojom::CustomProxyConnectionObserver>
+      observer_remote;
