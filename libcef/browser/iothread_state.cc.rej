 }
 
+#if BUILDFLAG(ARKWEB_DEVTOOLS)
+void CefIOThreadState::InitOnIOThread() {
+  CEF_REQUIRE_IOT();
+
+  // Add the default internal handlers.
+  scheme::RegisterInternalHandlers(this);
+}
+#endif // BUILDFLAG(ARKWEB_DEVTOOLS)
