@@ -228,6 +237,65 @@ static FILE* OpenFileForWriting(const std::string& output_file) {
 
 }  // namespace internal
 
+#if BUILDFLAG(IS_OHOS)
+static std::string g_ut_result_path_;
+// 类似 printf 函数，保存到文件
+GTEST_ATTRIBUTE_PRINTF_(1, 2)
+static void WriteUTResult(const char* fmt, ...) {
+  if (g_ut_result_path_.empty()) return;
+  FILE* file = fopen(g_ut_result_path_.c_str(), "a");
+  if (file == nullptr) return;
+  va_list args;
+  va_start(args, fmt);
+  vfprintf(file, fmt, args);
+  va_end(args);
+  fflush(file);
+  fclose(file);
+}
+
+static void ResetUTResultFile() {
+  if (g_ut_result_path_.empty()) return;
+  FILE* file = fopen(g_ut_result_path_.c_str(), "w");
+  if (file != nullptr) fclose(file);
+}
+
+static void UpdateUTResultForRetry(
+    const std::vector<std::string>& retried_tests,
+    const std::vector<bool>& retried_passed) {
+  if (g_ut_result_path_.empty()) return;
+  FILE* file = fopen(g_ut_result_path_.c_str(), "r");
+  if (file == nullptr) return;
+
+  std::vector<std::string> lines;
+  char buf[4096];
+  while (fgets(buf, sizeof(buf), file)) {
+    lines.push_back(buf);
+  }
+  fclose(file);
+
+  const std::string kFailed = "[  FAILED  ] ";
+  const std::string kOK     = "[       OK ] ";
+
+  for (size_t i = 0; i < retried_tests.size(); ++i) {
+    if (!retried_passed[i]) continue;
+    const std::string& name = retried_tests[i];
+    for (auto& line : lines) {
+      if (line.find(kFailed) == 0 && line.find(name) == kFailed.size()) {
+        line.replace(0, kFailed.size(), kOK);
+      }
+    }
+  }
+
+  file = fopen(g_ut_result_path_.c_str(), "w");
+  if (file == nullptr) return;
+  for (const auto& line : lines) {
+    fputs(line.c_str(), file);
+  }
+  fflush(file);
+  fclose(file);
+}
+#endif
